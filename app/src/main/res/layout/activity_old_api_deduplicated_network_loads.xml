<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".OldApiDeduplicatedNetworkLoadsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/playerOneLabelTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/deduplicated_network_loads_player_one"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <com.opensource.svgaplayer.SVGAImageView
            android:id="@+id/playerOneView"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/darker_gray" />

        <TextView
            android:id="@+id/playerTwoLabelTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/deduplicated_network_loads_player_two"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <com.opensource.svgaplayer.SVGAImageView
            android:id="@+id/playerTwoView"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/darker_gray" />

        <TextView
            android:id="@+id/playerThreeLabelTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/deduplicated_network_loads_player_three"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <com.opensource.svgaplayer.SVGAImageView
            android:id="@+id/playerThreeView"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/darker_gray" />

    </LinearLayout>
</ScrollView>
